---
import Layout from "../layouts/Layout.astro";
import FiftyFifty from "../components/templates/FiftyFifty/index.astro";
import ThreeQuarters from "../components/templates/ThreeQuarters/index.astro";
import Hero from "../components/organisms/Hero/index.astro";
import Description from "../components/organisms/Description/index.astro";
import ColorStripe from "../components/atoms/ColorStripe/index.astro";
import FourQuarters from "../components/templates/FourQuarters/index.astro";
import backgroundNeon from "../assets/background-neon.jpg";
---

<Layout pageTitle="Home">
    <FiftyFifty>
        <div slot="left" class="bg-image"></div>
        <Hero slot="right" />
    </FiftyFifty>
    <ThreeQuarters>
        <Description
            slot="main-top-left"
            title="La escuela que cambió la historia del diseño"
            content="Fundada en 1919 por Walter Gropius en Alemania, la Bauhaus fue más que una escuela: fue un movimiento que unió arte, diseño, arquitectura y tecnología. Su filosofía era simple pero revolucionaria: la forma debe seguir a la función. Todo debía tener un propósito claro, una estructura racional y una estética accesible para todos."
        />
        <div slot="main-top-right" class="bg-image">
            <!-- 1/3 del ancho superior -->
        </div>
        <ColorStripe
            slot="main-middle"
            backgroundColor="#F9B700"
            text="Un siglo después, su influencia sigue viva."
            color="black"
        />
        <div slot="main-bottom-left" class="bg-image">
            <!-- 2/3 del ancho inferior -->
        </div>
        <Description
            slot="main-bottom-right"
            title="Inspirada en 1919, creada para la era digital"
            content="La Bauhaus sentó las bases del diseño moderno: el uso de la geometría, la tipografía limpia, los colores primarios y la producción modular. Hoy, su legado se refleja en cada interfaz minimalista, en cada sistema de diseño, y en cada experiencia digital centrada en el usuario."
        />
        <span slot="side-title">Principios Bauhaus</span>
        <div slot="side-sections">
            <section>
                <h3>Forma y Función</h3>
                <p>El diseño debe servir un propósito claro y práctico.</p>
            </section>
            <section>
                <h3>Simplicidad</h3>
                <p>Eliminar lo innecesario para destacar lo esencial.</p>
            </section>
            <section>
                <h3>Geometría</h3>
                <p>
                    Uso de formas básicas como círculos, cuadrados y triángulos.
                </p>
            </section>
        </div>
    </ThreeQuarters>
    <ColorStripe
        backgroundColor="#0063C2"
        text="Bauhaus UI es una reinterpretación contemporánea de esa visión"
        color="white"
    />
    <FourQuarters
        backgroundImage={backgroundNeon.src}
        section={{
            title: "El arte de unir forma y función",
            description:
                "Esta librería UX/UI nace del deseo de crear componentes que no solo luzcan bien, sino que piensen como diseñadores. Cada elemento visual fue concebido bajo los principios de la Bauhaus: claridad, equilibrio, modularidad y propósito.",
        }}
    />
    <ColorStripe
        backgroundColor="#AE3624"
        text="“El diseño no es solo cómo se ve, sino cómo funciona.” — Walter Gropius"
        color="white"
    />
</Layout>

<style>
    .bg-image {
        background-image: url("../assets/background-neon.jpg");
        background-size: cover;
        background-position: center;
        width: 100%;
        min-height: 100%;
    }
</style>
